{
  "id": "in.gxanshu.postcard",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "command": "postcard",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--device=dri",
    "--socket=wayland",
    "--talk-name=org.freedesktop.secrets"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/man",
    "/share/doc",
    "/share/gtk-doc",
    "/share/man",
    "/share/pkgconfig",
    "*.la",
    "*.a"
  ],
  "modules": [
    {
      "name": "blueprint-compiler",
      "buildsystem": "meson",
      "cleanup": [
        "*"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://gitlab.gnome.org/jwestman/blueprint-compiler",
          "tag": "v0.20.4",
          "commit": "cb333fb74a6cb0bd7506f05c222e8e057fa0a2e9"
        }
      ]
    },
    {
      "name": "postcard",
      "builddir": true,
      "buildsystem": "meson",
      "sources": [
        {
          "type": "dir",
          "path": ".",
          "skip": [
            "build",
            ".flatpak",
            ".flatpak-builder",
            ".git",
            "postcard-*.flatpak"
          ]
        }
      ],
      "config-opts": [
        "--libdir=lib"
      ]
    }
  ]
}
